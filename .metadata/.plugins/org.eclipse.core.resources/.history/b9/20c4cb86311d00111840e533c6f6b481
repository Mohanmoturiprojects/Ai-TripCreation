package com.example.logikal.ser;

import java.time.LocalDateTime;

import org.springframework.ai.chat.client.ChatClient;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import com.example.logikal.Entity.Trip;
import com.example.logikal.Entity.Vehicle;
import com.example.logikal.Entity.WhDistance;
import com.example.logikal.model.TripCommand;
import com.example.logikal.repo.Distancerepo;
import com.example.logikal.repo.Triprepo;
import com.example.logikal.repo.Vehiclerepo;
import com.fasterxml.jackson.databind.ObjectMapper;

@Service
public class Tripservice {

    @Autowired
    private Triprepo triprepo;

    @Autowired
    private Distancerepo distancerepo;

    @Autowired
    private Vehiclerepo vehiclerepo;

    @Autowired
    private ChatClient chatClient;

    public String processQuestion(String question) {

        System.out.println("====================================");
        System.out.println("User Question: " + question);
        System.out.println("Calling Ollama AI...");
        System.out.println("====================================");

        // STEP 1 : Ask AI to extract JSON
        String aiResponse = chatClient.prompt()
                .user("""
                        Extract trip details from the text.

                        Return ONLY JSON in this format:

                        {
                          "startlocation": "",
                          "destination": "",
                          "vehicleId": 0,
                          "startTime": ""
                        }

                        Text: """ + question)
                .call()
                .content();

        System.out.println("AI Raw Response:");
        System.out.println(aiResponse);

        // STEP 2 : Parse JSON
        TripCommand command = parseJson(aiResponse);

        System.out.println("Parsed Command Object:");
        System.out.println("Start Location: " + command.getStartlocation());
        System.out.println("Destination: " + command.getDestination());
        System.out.println("Vehicle ID: " + command.getVehicleId());
        System.out.println("Start Time: " + command.getStartTime());

        // STEP 3 : Validate Locations
        if (command.getStartlocation() == null || command.getDestination() == null) {
            throw new RuntimeException("AI could not extract start or destination location.");
        }

        // STEP 4 : Start Time Handling
        LocalDateTime start;

        if (command.getStartTime() == null || command.getStartTime().isBlank()) {
            start = LocalDateTime.now();
            System.out.println("StartTime not provided. Using current time.");
        } else {
            start = LocalDateTime.parse(command.getStartTime());
        }

        System.out.println("Trip Start Time: " + start);

        // STEP 5 : Validate Vehicle
        System.out.println("Fetching Vehicle from DB...");

        Vehicle vehicle = vehiclerepo
                .findById(command.getVehicleId())
                .orElseThrow(() -> new RuntimeException("Vehicle not found with ID: " + command.getVehicleId()));

        System.out.println("Vehicle Found: " + vehicle.getId());

        // STEP 6 : Fetch Distance
        System.out.println("Fetching Warehouse Distance...");

        WhDistance distance = distancerepo
                .findByStartLocationAndDestination(
                        command.getStartlocation(),
                        command.getDestination());

        if (distance == null) {
            throw new RuntimeException("Distance not found between "
                    + command.getStartlocation() + " and " + command.getDestination());
        }

        System.out.println("Distance Record Found: " + distance.getDistanceKm() + " KM");

        Double km = distance.getDistanceKm();

        // STEP 7 : Calculate ETA
        double avgSpeed = 50; // km/h

        long travelHours = (long) (km / avgSpeed);

        System.out.println("Travel Hours: " + travelHours);

        LocalDateTime arrival = start.plusHours(travelHours);

        System.out.println("Expected Arrival Time: " + arrival);

        // STEP 8 : Create Trip
        Trip trip = new Trip();

        trip.setStartLocation(command.getStartlocation());
        trip.setDestination(command.getDestination());
        trip.setStartTime(start);
        trip.setExpectedArrival(arrival);
        trip.setVehicleId(vehicle.getId());

        System.out.println("Saving Trip into database...");

        triprepo.save(trip);

        System.out.println("Trip Saved Successfully!");
        System.out.println("====================================");

        return "Trip created successfully. ETA: " + arrival;
    }

    // JSON Parsing Method
    private TripCommand parseJson(String aiResponse) {

        try {

            int start = aiResponse.indexOf("{");
            int end = aiResponse.lastIndexOf("}") + 1;

            String json = aiResponse.substring(start, end);

            System.out.println("Clean JSON Extracted:");
            System.out.println(json);

            ObjectMapper mapper = new ObjectMapper();

            return mapper.readValue(json, TripCommand.class);

        } catch (Exception e) {

            throw new RuntimeException("Error parsing AI response: " + e.getMessage());
        }
    }
}